# Static fallback used only on non-subdomain local hosts unless forced.
VITE_API_BASE_URL="http://127.0.0.1:8000/api"

# For subdomain SaaS hosts, frontend resolves API as:
# <protocol>://<current-subdomain-host>:<VITE_API_PORT>/api
VITE_API_PROTOCOL="http"
VITE_API_PORT="8000"

# Set true only when you intentionally want one fixed API URL for every host.
VITE_API_FORCE_STATIC_BASE_URL="false"
