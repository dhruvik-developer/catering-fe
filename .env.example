# ============================================================
# PRODUCTION (server) — admin.trayza.in / *.trayza.in
# ============================================================
# Subdomain hosts par frontend automatically API URL build karta hai:
#   <VITE_API_PROTOCOL>://<current-hostname><:VITE_API_PORT>/api
# Yaani admin.trayza.in -> https://admin.trayza.in/api
#
# Isliye VITE_API_BASE_URL khaali rakho.
# Port khaali rakho — Nginx 443 (HTTPS) / 80 (HTTP) par sunta hai.

VITE_API_PROTOCOL="https"
VITE_API_PORT=""
VITE_API_FORCE_STATIC_BASE_URL="false"
VITE_API_BASE_URL=""

# ============================================================
# LOCAL DEV (uncomment + comment out production block above)
# ============================================================
# VITE_API_BASE_URL="http://admin.localhost:8006/api"
# VITE_API_PROTOCOL="http"
# VITE_API_PORT="8006"
# VITE_API_FORCE_STATIC_BASE_URL="false"

# ============================================================
# NOTES
# ============================================================
# 1. Vite env vars BUILD TIME par bake hote hain.
#    .env change karne ke baad `npm run build` zaroor chalao.
# 2. VITE_API_FORCE_STATIC_BASE_URL="true" sirf tab karo jab
#    har host (subdomain bhi) ek hi fixed API URL use kare.
# 3. HTTPS production me zaroori hai — warna page HTTPS aur API
#    HTTP par hone par browser mixed-content block karega.
